<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GuiAvalonia.MainWindow"
        Title="YouTubeGUI - Avalonia" Width="700" Height="320">
  <StackPanel Margin="10" Spacing="8">
    <TextBlock Text="YouTube link:"/>
    <TextBox Name="UrlBox" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <StackPanel Width="260">
        <TextBlock Text="Mode:"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <RadioButton Name="AudioRadio" Content="Audio"/>
          <RadioButton Name="VideoRadio" Content="Video"/>
        </StackPanel>
        <TextBlock Text="Formats:"/>
        <ComboBox Name="AudioFormat" Width="200"/>
        <ComboBox Name="VideoFormat" Width="200"/>
      </StackPanel>

      <StackPanel Width="380">
        <TextBlock Text="Quality:"/>
        <ComboBox Name="QualityBox" />
        <TextBlock Text="Sample Rate (audio):"/>
        <ComboBox Name="SampleRateBox" />
      </StackPanel>
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Output:" VerticalAlignment="Center"/>
      <TextBox Name="OutBox" Width="420"/>
      <Button Name="BrowseBtn" Content="Browse" Width="80"/>
    </StackPanel>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Name="DownloadBtn" Content="Download" Width="120"/>
    </StackPanel>
  </StackPanel>
</Window>
